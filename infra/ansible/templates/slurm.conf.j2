ClusterName={{ slurm_cluster_name }}
ControlMachine={{ slurm_controller_host }}

SlurmUser=slurm
AuthType=auth/munge

StateSaveLocation={{ slurm_state_dir_controller }}
SlurmdSpoolDir={{ slurm_state_dir_worker }}

SlurmctldLogFile={{ slurm_log_dir }}/slurmctld.log
SlurmdLogFile={{ slurm_log_dir }}/slurmd.log
SlurmctldPidFile=/run/slurm/slurmctld.pid
SlurmdPidFile=/run/slurm/slurmd.pid

SwitchType=switch/none
MpiDefault=none

SlurmctldPort=6817
SlurmdPort=6818

ProctrackType=proctrack/linuxproc
ReturnToService=1

{% for node in slurm_nodes %}
NodeName={{ node.name }} Sockets={{ node.sockets }} CoresPerSocket={{ node.cores_per_socket }} ThreadsPerCore={{ node.threads_per_core }} RealMemory={{ node.memory }} State=UNKNOWN
{% endfor %}

PartitionName={{ slurm_partition_name }} Nodes=ALL Default=YES MaxTime=INFINITE State=UP
