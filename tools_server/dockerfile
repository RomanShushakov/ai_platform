FROM rust:1.94.1-bookworm AS builder
WORKDIR /app

COPY . .
RUN cargo build -p tools-server --release

FROM debian:bookworm
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/tools-server /usr/local/bin/tools-server

EXPOSE 3001
CMD ["/usr/local/bin/tools-server"]
